# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# ── Required ──────────────────────────────────────────────────────────
SERPER_API_KEY=
ZUHAL_API_KEY=

# ── Racknerd SMTP backend (required unless racknerd_enabled=false) ─────
RACKNERD_HOST=vps.example.com
RACKNERD_SSH_USER=egress
RACKNERD_SSH_KEY=~/.ssh/racknerd_egress
# RACKNERD_SSH_PORT=22
# RACKNERD_SOCKS_PORT=1080
# RACKNERD_CONCURRENCY=10
# RACKNERD_SMTP_TIMEOUT_S=15.0

# ── bbops async backend ───────────────────────────────────────────────
BBOPS_BASE_URL=https://email-verifier.bbops.io
# BBOPS_BATCH_SIZE=500
# BBOPS_MAX_INFLIGHT=12

# ── Dispatcher ────────────────────────────────────────────────────────
# DISPATCH_CONCURRENCY=20
# DISPATCH_BACKEND_TIMEOUT_S=60.0
