# Copy this file to .env and fill in your values.
# Never commit .env — it is listed in .gitignore.

# ── Required ──────────────────────────────────────────────────────────
SERPER_API_KEY=
ZUHAL_API_KEY=

# ── Racknerd SMTP backend (required unless racknerd_enabled=false) ─────
RACKNERD_HOST=vps.example.com
RACKNERD_SSH_USER=egress          # SSH tunnel user for SMTP relaying
RACKNERD_SSH_KEY=~/.ssh/racknerd_egress
# RACKNERD_SSH_PORT=22
# RACKNERD_SOCKS_PORT=1080
# RACKNERD_CONCURRENCY=25
# RACKNERD_SMTP_TIMEOUT_S=8.0
# RACKNERD_HELO_HOSTNAME=          # override SMTP HELO/MAIL FROM FQDN; fleet defaults to each worker's rDNS/PTR

# ── VPS deploy auth (used by scripts/deploy.sh and _common.sh) ────────
# Set ONE of the following. VPS_PASS takes priority over SSH key auth.
VPS_DEPLOY_USER=root              # deploy SSH user (defaults to RACKNERD_SSH_USER if unset)
VPS_PASS=                         # password auth (requires: brew install sshpass)
                                  # leave blank to use RACKNERD_SSH_KEY instead

# ── Cherry Servers SMTP fleet (migration target — items 1/5/6) ────────
# Provision + manage workers:  python -m pipeline.fleet provision --count 4
# Run with the fleet as SMTP backend:  python -m pipeline run ... --cherry-enabled
CHERRY_AUTH_TOKEN=                # Cherry API token (portal → settings/api-keys)
CHERRY_PROJECT_ID=                # numeric project id (e.g. 276218)
CHERRY_TEAM_ID=                   # numeric team id (for credit checks / auto-heal guard)
# CHERRY_REGION=EU-Nord-1
# CHERRY_PLAN=B2-1-1gb-20s-shared
# CHERRY_SSH_KEY=~/.ssh/cherry_fleet   # private key; <path>.pub is registered with Cherry
# SMTP_HOSTS=["1.2.3.4","5.6.7.8"]     # explicit worker IPs (JSON) — overrides the inventory
# FLEET_CREDIT_FLOOR_EUR=0.10          # auto-heal refuses to provision below this
# FLEET_MAX_REPROVISIONS=10            # per-run cap on auto-heal reprovisions
# FLEET_SCALE_MAX=10

# ── Durable state backup to R2/S3 (item 2; off by default) ────────────
# BACKUP_ENABLED=true
# BACKUP_R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com/<bucket>
R2_ACCESS_KEY_ID=                 # R2 access key id (S3-compatible)
R2_SECRET_ACCESS_KEY=             # R2 secret access key
# BACKUP_DIR=output/backup         # optional local copy alongside R2
# BACKUP_INTERVAL_S=300

# ── bbops async backend ───────────────────────────────────────────────
BBOPS_BASE_URL=https://email-verifier.bbops.io
# BBOPS_BATCH_SIZE=500
# BBOPS_MAX_INFLIGHT=12

# ── ZeroBounce (post-pipeline re-validation) ──────────────────────────
ZEROBOUNCE_API_KEY=          # Master key or sub-account key

# ── Dispatcher ────────────────────────────────────────────────────────
# DISPATCH_CONCURRENCY=50
# DISPATCH_BACKEND_TIMEOUT_S=60.0
